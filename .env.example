# ==============================================================================
# MODELO DE VARIÁVEIS DE AMBIENTE (.env.example)
# ==============================================================================
# COPIE ESTE ARQUIVO PARA .env.dev OU .env.prod E PREENCHA COM SEUS VALORES:
# - Para desenvolvimento local:  cp .env.example .env.dev
# - Para ambiente de produção:   cp .env.example .env.prod
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BANCO DE DADOS (PostgreSQL)
# ------------------------------------------------------------------------------
DB_HOST=postgres
DB_NAME=techcontent
DB_USER=techuser
DB_PASSWORD=sua_senha_segura_aqui

# ------------------------------------------------------------------------------
# 2. BACKEND (Java Spring Boot)
# ------------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=dev
ML_SERVICE_URL=http://ia-service:8000

# ------------------------------------------------------------------------------
# 3. IA & MACHINE LEARNING (Python FastAPI)
# ------------------------------------------------------------------------------
PORT=8000

# ------------------------------------------------------------------------------
# 4. FRONTEND (React / Vite)
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8080

